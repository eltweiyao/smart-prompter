/**app.wxss**/
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
} 

page {
  background-color: #feffff;
  font-size: 16px;
  font-family: 'PingFang SC', 'HarmonyOS Sans SC', 'MiSans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  color: #172033;
}

button {
  border: 0;
  box-sizing: border-box;
}

button::after {
  border: 0;
}
