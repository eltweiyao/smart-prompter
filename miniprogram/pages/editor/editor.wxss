.container-editor {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  background: #f3f5f8;
  color: #141923;
}

.editor-header {
  padding: 30rpx 30rpx 6rpx;
}

.editor-title {
  font-size: 40rpx;
  line-height: 1.15;
  font-weight: 800;
  color: #111827;
}

.editor-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #687385;
}

.page-body {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  padding: 24rpx 30rpx 0;
  box-sizing: border-box;
}

.input-title {
  height: 88rpx;
  font-size: 32rpx;
  font-weight: 700;
  padding: 0 24rpx;
  background: #ffffff;
  border: 1rpx solid #e4e8ef;
  border-radius: 22rpx;
  margin-bottom: 18rpx;
  box-sizing: border-box;
  color: #202736;
}

.content-wrapper {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  background: #ffffff;
  border: 1rpx solid #e4e8ef;
  border-radius: 26rpx;
  box-shadow: 0 10rpx 30rpx rgba(20, 25, 35, 0.045);
  overflow: hidden;
}

.content-head {
  flex: 0 0 auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx 0;
  color: #687385;
  font-size: 24rpx;
}

.content-head text:first-child {
  color: #202736;
  font-size: 28rpx;
  font-weight: 700;
}

.input-content {
  flex: 1;
  min-height: 0;
  width: 100%;
  font-size: 30rpx;
  padding: 18rpx 24rpx;
  box-sizing: border-box;
  line-height: 1.64;
  color: #1f2937;
}

.input-footer {
  flex: 0 0 auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  padding: 16rpx 20rpx 20rpx;
  border-top: 1rpx solid #eef2f6;
}

.char-count {
  font-size: 23rpx;
  color: #8a94a6;
}

.right-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.beautify-btn,
.clear-btn {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.beautify-btn {
  color: #0b63ce;
  background: #eaf2ff;
}

.clear-btn {
  color: #b42318;
  background: #fff0ee;
}

.btn-group {
  flex: 0 0 auto;
  padding: 20rpx 30rpx 40rpx;
  box-sizing: border-box;
}

.btn-save {
  width: 100% !important;
  height: 86rpx;
  line-height: 86rpx;
  margin: 0;
  padding: 0;
  background: #1167d8;
  color: #fff;
  border-radius: 999rpx;
  font-size: 29rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(17, 103, 216, 0.24);
}

.btn-save:active {
  transform: scale(0.985);
}
