.container-editor {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  background: #feffff;
  color: #172033;
}

.editor-header {
  padding: 18rpx 30rpx 6rpx;
}

.editor-title {
  font-family: 'PingFang SC', 'HarmonyOS Sans SC', 'MiSans', sans-serif;
  font-size: 48rpx;
  line-height: 1.15;
  font-weight: 900;
  color: #00b8d9;
}

.editor-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.page-body {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  padding: 24rpx 30rpx 0;
  box-sizing: border-box;
}

.input-title {
  height: 88rpx;
  font-size: 32rpx;
  font-weight: 700;
  padding: 0 24rpx;
  background: #ffffff;
  border: 0;
  border-radius: 22rpx;
  margin-bottom: 18rpx;
  box-sizing: border-box;
  color: #172033;
}

.content-wrapper {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  background: #ffffff;
  border: 0;
  border-radius: 26rpx;
  box-shadow: 0 14rpx 38rpx rgba(0, 166, 166, 0.12);
  overflow: hidden;
}

.content-head {
  flex: 0 0 auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx 0;
  color: #64748b;
  font-size: 24rpx;
}

.content-head text:first-child {
  color: #172033;
  font-size: 28rpx;
  font-weight: 700;
}

.input-content {
  flex: 1;
  min-height: 0;
  width: 100%;
  font-size: 30rpx;
  padding: 18rpx 24rpx;
  box-sizing: border-box;
  line-height: 1.64;
  color: #172033;
}

.input-footer {
  flex: 0 0 auto;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  padding: 16rpx 20rpx 20rpx;
  border-top: 1rpx solid #dffaf6;
}

.char-count {
  font-size: 23rpx;
  color: #94a3b8;
}

.right-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.beautify-btn,
.clear-btn {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.beautify-btn {
  color: #078bc7;
  background: #e0f7ff;
}

.clear-btn {
  color: #475569;
  background: #f1f5f9;
}

.btn-group {
  flex: 0 0 auto;
  padding: 20rpx 30rpx 40rpx;
  box-sizing: border-box;
}

.btn-save {
  width: 100% !important;
  height: 86rpx;
  line-height: 86rpx;
  margin: 0;
  padding: 0;
  background: #00a6d6;
  color: #fff;
  border-radius: 999rpx;
  font-size: 29rpx;
  font-weight: 700;
  box-shadow: 0 10rpx 22rpx rgba(0, 166, 214, 0.22);
}

.btn-save:active {
  transform: scale(0.985);
}
