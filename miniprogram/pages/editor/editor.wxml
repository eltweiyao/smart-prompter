<view class="container-editor">
  <view class="page-body">
    <input class="input-title" placeholder="请输入标题" value="{{title}}" bindinput="onTitleInput" />
    <view class="content-wrapper">
      <textarea class="input-content" placeholder="请输入提词内容..." value="{{content}}" bindinput="onContentInput" maxlength="-1"></textarea>
      <view class="input-footer">
        <text class="char-count">{{content.length}} 字</text>
        <view class="right-actions">
          <view class="beautify-btn" bindtap="processContent" wx:if="{{content.length > 0}}">✨ 美化</view>
          <view class="clear-btn" bindtap="clearContent" wx:if="{{content.length > 0}}">清空</view>
        </view>
      </view>
    </view>
  </view>
  
  <view class="btn-group">
    <button class="btn-save" bindtap="saveScript">保存</button>
  </view>
</view>