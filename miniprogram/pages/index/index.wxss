.container-home {
  min-height: 100vh;
  padding: 16rpx 28rpx 28rpx;
  box-sizing: border-box;
  background: #feffff;
  color: #172033;
}

.home-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  margin: 0 0 26rpx;
}

.home-title {
  font-family: 'PingFang SC', 'HarmonyOS Sans SC', 'MiSans', sans-serif;
  font-size: 60rpx;
  line-height: 1.15;
  font-weight: 900;
  color: #00b8d9;
}

.home-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748b;
}

.home-status {
  flex: 0 0 auto;
  margin-top: 4rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #dffaf6;
  color: #008a98;
  font-size: 22rpx;
  font-weight: 600;
}

.input-section,
.controls-section {
  background: #ffffff;
  border: 0;
  border-radius: 26rpx;
  box-shadow: 0 14rpx 38rpx rgba(0, 166, 166, 0.12);
  box-sizing: border-box;
}

.input-section {
  flex: none;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  margin-bottom: 22rpx;
  transition: height 0.25s ease;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 28rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #172033;
}

.section-meta {
  font-size: 22rpx;
  color: #64748b;
}

.script-input {
  flex: 1;
  width: 100%;
  min-height: 0;
  font-size: 31rpx;
  line-height: 1.62;
  color: #172033;
}

.input-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  margin-top: 18rpx;
}

.resize-controls {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  background: #e8fbf8;
  border-radius: 999rpx;
  padding: 4rpx;
}

.resize-btn {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  font-size: 28rpx;
  color: #00a6a6;
}

.resize-btn:active {
  background: #ccfbf1;
}

.resize-label {
  padding: 0 10rpx;
  font-size: 22rpx;
  color: #64748b;
}

.right-actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 12rpx;
  min-width: 0;
}

.char-count {
  flex: 0 0 auto;
  font-size: 22rpx;
  color: #64748b;
}

.beautify-btn,
.clear-btn {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.beautify-btn {
  color: #078bc7;
  background: #e0f7ff;
}

.clear-btn {
  color: #475569;
  background: #f1f5f9;
}

.controls-section {
  padding: 24rpx;
  margin-bottom: 28rpx;
}

.options-group {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 22rpx;
}

.orientation-selector {
  flex: 1;
  display: flex;
  min-width: 0;
  background: #e8fbf8;
  border-radius: 999rpx;
  padding: 5rpx;
}

.option {
  flex: 1;
  text-align: center;
  padding: 13rpx 0;
  border-radius: 999rpx;
  font-size: 25rpx;
  color: #64748b;
}

.option.active {
  background: #ffffff;
  color: #00a6a6;
  font-weight: 700;
  box-shadow: 0 2rpx 10rpx rgba(0, 166, 166, 0.14);
}

.setting-item {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 25rpx;
  color: #334155;
}

.main-actions {
  display: flex;
  gap: 40rpx;
}

.btn-save,
.btn-start {
  height: 84rpx;
  line-height: 84rpx;
  border-radius: 999rpx;
  font-size: 29rpx;
  font-weight: 700;
  padding: 0;
  margin: 0;
}

.btn-save {
  flex: 2;
  background: #e8fbf8;
  color: #008a98;
}

.btn-start {
  flex: 5;
  background: #00a6d6;
  color: #fff;
  box-shadow: 0 10rpx 22rpx rgba(0, 166, 214, 0.22);
}

.btn-save:active,
.btn-start:active {
  transform: scale(0.985);
}

.history-section {
  padding-bottom: 24rpx;
}

.history-list {
  display: flex;
  height: 208rpx;
}

.history-card {
  position: relative;
  flex: 0 0 260rpx;
  height: 182rpx;
  background: #ffffff;
  border: 0;
  border-radius: 22rpx;
  padding: 18rpx;
  margin-right: 16rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-shadow: 0 10rpx 28rpx rgba(0, 166, 166, 0.11);
  box-sizing: border-box;
}

.history-delete {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 38rpx;
  height: 38rpx;
  line-height: 36rpx;
  text-align: center;
  border-radius: 50%;
  background: rgba(241, 245, 249, 0.94);
  color: #64748b;
  font-size: 30rpx;
  font-weight: 400;
  z-index: 2;
}

.history-delete:active {
  background: #e2e8f0;
  color: #334155;
}

.history-card:active {
  background: #e8fbf8;
}

.card-content {
  font-size: 25rpx;
  color: #334155;
  padding-right: 28rpx;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  line-height: 1.38;
}

.card-date {
  font-size: 21rpx;
  color: #94a3b8;
  margin-top: 8rpx;
}

.empty-history {
  width: 100%;
  height: 150rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #94a3b8;
  font-size: 25rpx;
  background: #ffffff;
  border: 0;
  border-radius: 22rpx;
}
