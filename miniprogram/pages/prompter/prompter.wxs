
function targetYChange(newVal, oldVal, ownerInstance, instance) {
  var content = ownerInstance.selectComponent('.prompter-content');
  if (!content) return;

  if (newVal === null || newVal === undefined) return;
  
  var dataset = content.getDataset();
  var mode = dataset.mode || 'basic';
  var isDragging = dataset.dragging === true || dataset.dragging === 'true';

  if (isDragging) {
    content.setStyle({
      'transform': 'translateY(' + newVal + 'px)',
      'transition': 'none'
    });
    return;
  }

  if (mode === 'smart') {
    // 智能跟随由 JS tick 小步推进，短线性过渡能减少响应滞后。
    content.setStyle({
      'transform': 'translateY(' + newVal + 'px)',
      'transition': 'transform 0.12s linear'
    });
  } else {
    // 基础模式下，WXS 不应干预 transition 样式，
    // 否则会覆盖 JS 设置的匀速线性动画，导致瞬间跳转。
    content.setStyle({
      'transform': 'translateY(' + newVal + 'px)'
    });
  }
}

module.exports = {
  targetYChange: targetYChange
};
